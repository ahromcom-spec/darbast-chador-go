############
# Secrets — Generate these! Never commit .env to git
# Use: openssl rand -base64 32
############

# PostgreSQL
POSTGRES_PASSWORD=your-super-secret-db-password
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# JWT — Must be at least 32 characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters
JWT_EXP=3600

# Anon / Service Role keys — Generate with jwt.io using JWT_SECRET
# Anon key payload: {"role":"anon","iss":"supabase","iat":1700000000,"exp":2000000000}
# Service key payload: {"role":"service_role","iss":"supabase","iat":1700000000,"exp":2000000000}
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

# URLs
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

# Auth
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_PHONE_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_PHONE_AUTOCONFIRM=false

# Kong
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# Realtime
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# Supabase Studio (optional, not included in compose)
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
STUDIO_PORT=3333
